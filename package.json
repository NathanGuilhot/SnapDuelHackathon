{
  "name": "hack",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:server & npm run dev:client & wait",
    "dev:client": "vite",
    "dev:server": "node --env-file=.env --import tsx --watch server/index.ts",
    "build": "tsc -b && vite build",
    "start": "NODE_ENV=production node --env-file=.env --import tsx server/index.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.34.0",
    "@ebay/nice-modal-react": "^1.2.13",
    "@emotion/react": "^11.14.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^9.0.0",
    "@fishjam-cloud/react-client": "^0.25.3",
    "@google/genai": "^1.46.0",
    "fastify": "^5.8.4",
    "lucide-react": "^1.7.0",
    "next-themes": "^0.4.6",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "uuid": "^13.0.0",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
